{
  "expo": {
    "name": "HalalHabits",
    "slug": "halalhabits",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "halalhabits",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halalhabits.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "package": "com.halalhabits.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "expo-sqlite",
      ["expo-notifications", { "icon": "./assets/icon.png", "color": "#0a0a14", "defaultChannel": "default", "enableBackgroundRemoteNotifications": false }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8de4f8d4-7ef2-4493-a524-84fd338a8a91"
      }
    }
  }
}
